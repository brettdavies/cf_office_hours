{
  "name": "@cf-office-hours/web",
  "version": "0.2.0",
  "license": "MIT OR Apache-2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:staging": "tsc && VITE_API_BASE_URL=https://cf-office-hours-api-staging.brettdavies.workers.dev vite build",
    "build:production": "tsc && VITE_API_BASE_URL=https://api.officehours.youcanjustdothings.io vite build",
    "deploy:staging": "npm run build:staging && wrangler deploy --env staging",
    "deploy:production": "npm run build:production && wrangler deploy --env production",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@cf-office-hours/shared": "*",
    "@hookform/resolvers": "^5.0.0",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@tanstack/react-virtual": "^3.14.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.22.0",
    "react": "^18.3.1",
    "react-day-picker": "^9.11.0",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.52.0",
    "react-router-dom": "^6.21.3",
    "recharts": "^3.9.0",
    "tailwind-merge": "^2.2.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.0.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@cf-office-hours/config": "*",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.2",
    "jsdom": "^29.1.1",
    "msw": "^2.11.3",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.1",
    "vite": "^7.3.6",
    "vite-bundle-analyzer": "^1.2.3",
    "vitest": "^4.0.0"
  }
}

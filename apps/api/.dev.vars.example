# Local Development Secrets for `wrangler dev`
# Copy this file to .dev.vars and replace with real values.

# HMAC secret used to sign and verify session JWTs
JWT_SECRET=your-local-jwt-secret

# Optional: OpenAI API key for the AI-based matching engine
# OPENAI_API_KEY=sk-...

# Optional: Resend API key for sending emails (logs to console when unset)
# RESEND_API_KEY=re_...
